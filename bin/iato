#!/usr/bin/env bash
set -euo pipefail

usage(){
  cat <<'USAGE'
IĀTŌ-V7 CLI
Usage: iato [scan] [--config <path>] [--dry-run] [--help]
USAGE
}

cmd="scan"
if [[ ${1:-} != "" && ${1:-} != -* ]]; then cmd="$1"; shift; fi
[[ "$cmd" == "scan" ]] || { echo "Unknown command: $cmd"; usage; exit 2; }

CONFIG="config.local.toml"
DRY=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --config) CONFIG="${2:-}"; shift 2 ;;
    --dry-run) DRY=1; shift ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Unknown option: $1"; usage; exit 2 ;;
  esac
done

[[ -n "$CONFIG" ]] || { echo "Missing value for --config"; exit 2; }
[[ -f "$CONFIG" ]] || [[ "$CONFIG" == */* || "$CONFIG" == .* ]] || CONFIG="config.toml"
[[ -f "$CONFIG" ]] || { echo "Config not found: $CONFIG"; echo "Try: cp config.toml config.local.toml"; exit 1; }
[[ -f "lean/iato_v7/scripts/nmap_path_audit_orchestrator.py" ]] || {
  echo "Run from repo root (missing lean/iato_v7/scripts/nmap_path_audit_orchestrator.py)"; exit 1; }
command -v python3 >/dev/null || { echo "python3 not found. Install: sudo apt install -y python3"; exit 127; }
command -v nmap >/dev/null || { echo "nmap not found. Install: sudo apt install -y nmap"; exit 127; }

echo "IĀTŌ-V7: Auditing your declared intent..."
args=(python3 lean/iato_v7/scripts/nmap_path_audit_orchestrator.py --config "$CONFIG")
if [[ "$DRY" -eq 1 ]]; then
  echo "Dry-run mode: Showing deterministic Nmap command only."
  args+=(--dry-run)
fi

set +e
"${args[@]}"
rc=$?
set -e

if [[ $rc -eq 0 ]]; then
  echo "Success: clean audit artifact generated."
fi
exit $rc
